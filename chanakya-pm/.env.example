# ── Chanakya PM — Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in your values before starting the server.
# Never commit .env to source control.

# ── Server ────────────────────────────────────────────────────────────────────
# PORT is set automatically by Railway/Render/Heroku — only set it manually on a VPS.
PORT=3000
NODE_ENV=production

# ── JWT ───────────────────────────────────────────────────────────────────────
# Required. Generate a strong secret:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-strong-random-secret
JWT_EXPIRES_IN=7d

# ── Google Login (optional) ───────────────────────────────────────────────────
# Leave blank to disable Google login entirely.
# Set to your Google Cloud OAuth 2.0 Client ID to enable it.
GOOGLE_CLIENT_ID=

# Comma-separated list of email domains that can sign in via Google without
# being pre-seeded in data/users.json. Accounts are auto-created on first
# sign-in with 'edit' permission (admin can later promote/demote in the DB
# or by editing users.json). Leave blank to require explicit pre-seeding.
AUTO_PROVISION_DOMAINS=whitelotusgroup.in

# ── CORS (optional) ───────────────────────────────────────────────────────────
# Leave blank when the API and frontend are served from the same domain (recommended).
# Set to a comma-separated list of origins only if they are on separate domains.
# Example: https://pm.yourdomain.com
ALLOWED_ORIGINS=
